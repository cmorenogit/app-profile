---
import { ProjectsSection } from './ProjectsSection';
---

<section
  id="projects"
  class="fade-in mb-24 scroll-mt-24 lg:mb-36 lg:scroll-mt-24"
>
  <h2 class="section-heading">Projects</h2>
  <ProjectsSection client:load />

  <div class="mt-12 flex flex-col gap-4 sm:flex-row sm:gap-8">
    <a
      href="/archive"
      class="group inline-flex items-center font-medium text-white hover:text-accent transition-colors"
    >
      View Full Project Archive
      <span class="ml-1 transition-transform group-hover:translate-x-2">→</span>
    </a>
    <a
      href="/playground"
      class="group inline-flex items-center font-medium text-accent-secondary hover:text-accent transition-colors"
    >
      Try AI Playground
      <span class="ml-1 transition-transform group-hover:translate-x-2">→</span>
    </a>
  </div>
</section>
