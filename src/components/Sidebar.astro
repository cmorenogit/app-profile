---
import { Navigation } from './Navigation';
import SocialLinks from './SocialLinks.astro';
---

<header class="pt-6 lg:sticky lg:top-0 lg:flex lg:h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24 lg:pt-24">
  <div>
    <div class="mb-4">
      <span class="status-badge">Building semantic memory for AI assistants</span>
    </div>

    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      <a href="/" class="gradient-text">Cesar Moreno</a>
    </h1>
    <h2 class="mt-3 text-lg font-medium tracking-tight text-white sm:text-xl">
      Full Stack &middot; AI Engineer
    </h2>
    <p class="mt-1 font-mono text-sm text-accent-secondary">
      AI Agents &middot; Developer Tools &middot; Multi-LLM Systems
    </p>
    <p class="mt-4 max-w-xs leading-relaxed text-slate-light">
      I build AI developer tools and multi-agent systems in production —
      from orchestration platforms to semantic memory,
      TypeScript to Rust.
    </p>

    <div class="mt-12 lg:mt-16">
      <Navigation client:load />
    </div>
  </div>

  <div class="mt-6 mb-8 lg:mt-0 lg:mb-0">
    <SocialLinks />
  </div>
</header>
