---
import type { Project } from '@/types';

interface Props {
  project: Project;
}
const { project } = Astro.props;

const hasImage = project.image !== null;
const hasLink = project.liveUrl !== null;
const Tag = hasLink ? 'a' : 'div';
---

<div class="group relative p-4 mb-2 rounded-xl border border-transparent transition-[background-color,border-color,box-shadow] duration-300 ease-out lg:hover:!opacity-100 lg:group-hover/list:opacity-50 lg:hover:bg-navy-light/50 lg:hover:border-accent/8 lg:hover:shadow-[0_0_20px_rgba(100,255,218,0.03)]">

  {hasLink ? (
    <a
      href={project.liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block"
    >
      <h3 class="font-medium leading-snug text-slate-lightest">
        <span class="inline-flex items-baseline text-base font-medium leading-tight text-white group-hover:text-accent transition-colors">
          {project.title}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 inline-block h-4 w-4 shrink-0 transition-transform group-hover:-translate-y-1 group-hover:translate-x-1"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </span>
      </h3>
      <p class="mt-2 text-sm leading-normal text-slate-light">
        {project.description}
      </p>
      <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies used">
        {project.technologies.map((tech) => (
          <li>
            <span class="inline-block rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
              {tech}
            </span>
          </li>
        ))}
      </ul>
    </a>
  ) : (
    <div class="">
      <h3 class="font-medium leading-snug text-slate-lightest">
        <span class="inline-flex items-baseline text-base font-medium leading-tight text-white group-hover:text-accent transition-colors">
          {project.title}
        </span>
      </h3>
      <p class="mt-2 text-sm leading-normal text-slate-light">
        {project.description}
      </p>
      {project.githubUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center gap-1 text-sm font-medium text-slate hover:text-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          Source
        </a>
      )}
      <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies used">
        {project.technologies.map((tech) => (
          <li>
            <span class="inline-block rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
              {tech}
            </span>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
