---
const stats = [
  { number: '13+', label: 'Years Building' },
  { number: '97.5%', label: 'Token Reduction' },
  { number: '500K+', label: 'Users Served' },
];
---

<section class="fade-in mb-24 scroll-mt-24 lg:mb-36">
  <div class="stats-grid">
    {stats.map((stat) => (
      <div class="stat-card">
        <div class="stat-number">{stat.number}</div>
        <div class="stat-label">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
