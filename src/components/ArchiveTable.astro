---
import { archiveProjects } from '@/data/archive';

const externalLinkSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>';
---

<table class="w-full border-collapse text-left">
  <thead class="sticky top-0 z-10 border-b border-accent/10 bg-navy/95 backdrop-blur-sm">
    <tr>
      <th class="py-4 pr-8 text-xs font-bold uppercase tracking-wider text-slate">Year</th>
      <th class="py-4 pr-8 text-xs font-bold uppercase tracking-wider text-slate">Project</th>
      <th class="hidden py-4 pr-8 text-xs font-bold uppercase tracking-wider text-slate lg:table-cell">Made at</th>
      <th class="hidden py-4 pr-8 text-xs font-bold uppercase tracking-wider text-slate sm:table-cell">Built with</th>
      <th class="py-4 text-xs font-bold uppercase tracking-wider text-slate">Link</th>
    </tr>
  </thead>
  <tbody>
    {archiveProjects.map((project, i) => (
      <>
        <tr
          class="archive-row border-b border-navy-lightest/30 cursor-pointer transition-[background-color] duration-200 ease-out hover:bg-navy-light/40"
          data-index={i}
        >
          <td class="py-4 pr-8 font-mono text-sm text-accent/70">{project.year}</td>
          <td class="py-4 pr-8 font-medium text-white">{project.title}</td>
          <td class="hidden py-4 pr-8 text-sm text-slate lg:table-cell">{project.madeAt || "—"}</td>
          <td class="hidden py-4 pr-8 text-sm text-slate sm:table-cell">{project.technologies.join(" · ")}</td>
          <td class="py-4">
            {project.url ? (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate transition-colors duration-200 hover:text-accent"
                aria-label={`View ${project.title}`}
                onclick="event.stopPropagation()"
              >
                <Fragment set:html={externalLinkSvg} />
              </a>
            ) : (
              <span class="text-navy-lightest">—</span>
            )}
          </td>
        </tr>
        <tr class="archive-detail" data-index={i}>
          <td colspan="5" class="p-0 border-0">
            <div class="archive-detail-content overflow-hidden max-h-0 opacity-0 transition-all duration-300 ease-out">
              <div class="pb-5 pt-2 pr-8 pl-8 sm:pl-[76px] bg-navy-light/20 border-t border-accent/6">
                {project.description && (
                  <p class="text-sm text-slate-light leading-relaxed">{project.description}</p>
                )}
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  {project.technologies.map((tech) => (
                    <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
                      {tech}
                    </span>
                  ))}
                  {project.slug && (
                    <a
                      href={`/projects/${project.slug}?from=archive`}
                      class="ml-auto inline-flex items-center gap-1.5 rounded-lg bg-accent/10 border border-accent/15 px-3 py-1.5 text-xs font-medium text-accent hover:bg-accent/15 hover:border-accent/30 transition-all"
                      onclick="event.stopPropagation()"
                    >
                      View Details →
                    </a>
                  )}
                </div>
              </div>
            </div>
          </td>
        </tr>
      </>
    ))}
  </tbody>
</table>

<script>
  document.addEventListener('astro:page-load', () => {
  document.querySelectorAll('.archive-row').forEach(row => {
    row.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const idx = row.getAttribute('data-index');
      const content = document.querySelector(
        `.archive-detail[data-index="${idx}"] .archive-detail-content`
      ) as HTMLElement;
      if (!content) return;

      const isOpen = content.classList.contains('max-h-60');

      // Close others
      document.querySelectorAll('.archive-detail-content').forEach(d => {
        if (d !== content) {
          d.classList.add('max-h-0', 'opacity-0');
          d.classList.remove('max-h-60', 'opacity-100');
        }
      });

      // Toggle current
      if (isOpen) {
        content.classList.add('max-h-0', 'opacity-0');
        content.classList.remove('max-h-60', 'opacity-100');
      } else {
        content.classList.remove('max-h-0', 'opacity-0');
        content.classList.add('max-h-60', 'opacity-100');
      }
    });
  });
  });
</script>
