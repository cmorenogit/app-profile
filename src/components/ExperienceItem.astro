---
import type { Experience } from '@/types';
import TechTag from './TechTag.astro';

interface Props {
  experience: Experience;
}
const { experience } = Astro.props;
---

<div class="group relative grid gap-4 pb-8 transition-all sm:grid-cols-8 sm:gap-8 lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
  <div class="absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition-all lg:block lg:group-hover:bg-navy-light/50 lg:group-hover:shadow-[inset_0_1px_0_0_rgba(148,163,184,0.1)]"></div>

  <header class="z-10 text-xs font-semibold uppercase tracking-wide text-slate sm:col-span-2">
    {experience.period}
  </header>

  <div class="z-10 sm:col-span-6">
    <h3 class="font-medium leading-snug text-white">
      <span>{experience.title}</span>
      <span class="mx-2 text-slate">·</span>
      {experience.companyUrl ? (
        <a
          href={experience.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline"
        >
          {experience.company}
        </a>
      ) : (
        <span class="text-accent">{experience.company}</span>
      )}
    </h3>
    <p class="mt-1 text-sm text-slate">{experience.location}</p>
    <p class="mt-2 text-sm leading-relaxed text-slate-light">
      {experience.description}
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      {experience.technologies.map((tech) => (
        <TechTag tech={tech} />
      ))}
    </div>
  </div>
</div>
