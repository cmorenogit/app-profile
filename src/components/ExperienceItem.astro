---
import type { Experience } from '@/types';
import TechTag from './TechTag.astro';

interface Props {
  experience: Experience;
}
const { experience } = Astro.props;
---

<div class="group relative grid gap-4 p-4 mb-2 rounded-xl border border-transparent sm:grid-cols-8 sm:gap-8 transition-[background-color,border-color,box-shadow] duration-300 ease-out lg:hover:!opacity-100 lg:group-hover/list:opacity-50 lg:hover:bg-navy-light/50 lg:hover:border-accent/8 lg:hover:shadow-[0_0_20px_rgba(100,255,218,0.03)]">

  <header class="text-xs font-semibold uppercase tracking-wide text-slate sm:col-span-2">
    {experience.period}
  </header>

  <div class="sm:col-span-6">
    <h3 class="font-medium leading-snug text-white">
      <span>{experience.title}</span>
      <span class="mx-2 text-slate">·</span>
      {experience.companyUrl ? (
        <a
          href={experience.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline transition-colors"
        >
          {experience.company}
        </a>
      ) : (
        <span class="text-accent">{experience.company}</span>
      )}
    </h3>
    <p class="mt-1 text-sm text-slate">{experience.location}</p>
    <p class="mt-2 text-sm leading-relaxed text-slate-light">
      {experience.description}
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      {experience.technologies.map((tech) => (
        <TechTag tech={tech} />
      ))}
    </div>
  </div>
</div>
