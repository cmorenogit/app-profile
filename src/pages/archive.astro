---
import Layout from '@/layouts/Layout.astro';
import { SpotlightCursor } from '@/components/SpotlightCursor';
import ArchiveTable from '@/components/ArchiveTable.astro';
---

<Layout
  title="Archive | Cesar Moreno"
  description="A comprehensive list of projects I've worked on."
>
  <SpotlightCursor client:media="(min-width: 1024px)" />
  <main class="mx-auto max-w-5xl px-6 py-24 md:px-12 lg:px-24">
    <a
      href="/"
      class="group mb-6 inline-flex items-center gap-2 font-mono text-sm text-accent transition-colors hover:text-accent-hover"
    >
      <span class="transition-transform group-hover:-translate-x-1">←</span>
      Back to home
    </a>

    <h1 class="text-4xl font-bold sm:text-5xl">
      <span class="gradient-text">All Projects</span>
    </h1>
    <p class="mt-4 text-lg text-slate-light">
      A comprehensive list of projects I've worked on
    </p>

    <div class="mt-12 overflow-x-auto">
      <ArchiveTable />
    </div>
  </main>
</Layout>
