---
import Layout from '@/layouts/Layout.astro';
import { featuredProjects } from '@/data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return featuredProjects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      prev: featuredProjects[index - 1] ?? null,
      next: featuredProjects[index + 1] ?? null,
    },
  }));
};

const { project, prev, next } = Astro.props;
---

<Layout title={`${project.title} — Cesar Moreno`} description={project.description}>
  <div class="mx-auto max-w-3xl px-6 py-12 lg:py-24">
    <!-- Back link (dynamic based on ?from=archive) -->
    <a
      id="back-link"
      href="/#projects"
      class="group mb-10 inline-flex items-center text-sm font-medium text-accent hover:text-accent-hover transition-colors"
    >
      <span class="mr-2 transition-transform group-hover:-translate-x-2">←</span>
      <span id="back-label">Back to home</span>
    </a>
    <script>
      document.addEventListener('astro:page-load', () => {
        const params = new URLSearchParams(window.location.search);

        // Set origin in sessionStorage when arriving with ?from=archive
        if (params.get('from') === 'archive') {
          sessionStorage.setItem('project-origin', 'archive');
        }

        const fromArchive = sessionStorage.getItem('project-origin') === 'archive';
        const isProjectPage = window.location.pathname.startsWith('/projects/');

        // Clear origin when leaving project pages
        if (!isProjectPage) {
          sessionStorage.removeItem('project-origin');
          return;
        }

        if (fromArchive) {
          const link = document.getElementById('back-link') as HTMLAnchorElement;
          const label = document.getElementById('back-label');
          if (link) link.href = '/archive';
          if (label) label.textContent = 'Back to archive';
        }
      });
    </script>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="text-3xl font-bold text-white sm:text-4xl">
          {project.title}
        </h1>
        {project.status === "wip" && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/8 border border-accent/15 px-3 py-1 text-xs font-medium text-accent">
            <span class="h-1.5 w-1.5 rounded-full bg-accent animate-[pulse-dot_2s_ease-in-out_infinite]" />
            Work in Progress
          </span>
        )}
      </div>

      {project.longDescription ? (
        <div class="project-prose text-slate-light leading-relaxed" set:html={project.longDescription} />
      ) : (
        <p class="text-lg text-slate-light leading-relaxed">
          {project.description}
        </p>
      )}

      <!-- Tech tags -->
      <ul class="mt-6 flex flex-wrap gap-2" aria-label="Technologies used">
        {project.technologies.map((tech) => (
          <li>
            <span class="inline-block rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
              {tech}
            </span>
          </li>
        ))}
      </ul>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap gap-3">
        {project.githubUrl && (
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-accent/10 border border-accent/15 px-4 py-2.5 text-sm font-medium text-accent hover:bg-accent/15 hover:border-accent/30 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            View Source Code
          </a>
        )}
        {project.liveUrl && (
          <a
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-accent/10 border border-accent/15 px-4 py-2.5 text-sm font-medium text-accent hover:bg-accent/15 hover:border-accent/30 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            View Live
          </a>
        )}
      </div>
    </header>

    <!-- Features -->
    {project.features && project.features.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-6 text-sm font-bold uppercase tracking-[0.1em] text-slate">
          Key Features
        </h2>
        <div class="glass-card p-6">
          <ul class="space-y-3">
            {project.features.map((feature) => (
              <li class="flex items-start gap-3 text-slate-light">
                <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-accent/60" />
                <span class="text-sm leading-relaxed">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Screenshots placeholder -->
    {project.screenshots && project.screenshots.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-6 text-sm font-bold uppercase tracking-[0.1em] text-slate">
          Screenshots
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {project.screenshots.map((src, i) => (
            <img
              src={src}
              alt={`${project.title} screenshot ${i + 1}`}
              class="rounded-xl border border-accent/8"
              loading="lazy"
            />
          ))}
        </div>
      </section>
    )}

    <!-- Prev / Next navigation -->
    <nav class="mt-16 flex items-center justify-between border-t border-accent/8 pt-8">
      {prev ? (
        <a
          href={`/projects/${prev.slug}`}
          class="group flex flex-col gap-1 text-left"
        >
          <span class="text-xs font-medium uppercase tracking-widest text-slate">
            ← Previous
          </span>
          <span class="text-sm font-medium text-white group-hover:text-accent transition-colors">
            {prev.title}
          </span>
        </a>
      ) : (
        <div />
      )}
      {next ? (
        <a
          href={`/projects/${next.slug}`}
          class="group flex flex-col gap-1 text-right"
        >
          <span class="text-xs font-medium uppercase tracking-widest text-slate">
            Next →
          </span>
          <span class="text-sm font-medium text-white group-hover:text-accent transition-colors">
            {next.title}
          </span>
        </a>
      ) : (
        <div />
      )}
    </nav>
  </div>
</Layout>
