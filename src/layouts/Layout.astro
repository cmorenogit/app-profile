---
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-mono/400.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { ChatWidget } from '@/components/ChatWidget';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://cesarmoreno.dev');

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      mainEntity: { "@id": "https://cesarmoreno.dev/#person" },
      url: canonicalURL.href,
      name: title,
      description,
    },
    {
      "@type": "Person",
      "@id": "https://cesarmoreno.dev/#person",
      name: "Cesar Moreno",
      jobTitle: "Full Stack Engineer · AI",
      url: "https://cesarmoreno.dev",
      image: "https://cesarmoreno.dev/og-image.png",
      description:
        "Full Stack Engineer specializing in AI with 13+ years of production experience. Builds intelligent systems from multi-agent orchestration to scalable platforms across LATAM.",
      sameAs: [
        "https://linkedin.com/in/morenodev",
        "https://github.com/cmorenogit",
      ],
      worksFor: {
        "@type": "Organization",
        name: "Apprecio",
        url: "https://apprecio.com",
      },
      hasOccupation: {
        "@type": "Occupation",
        name: "Full Stack Engineer",
        skills:
          "TypeScript, AI Agents, LLM Orchestration, Multi-Agent Systems, Node.js, React, NestJS, Microservices, PostgreSQL, AWS",
      },
      knowsAbout: [
        "TypeScript",
        "JavaScript",
        "AI Agents",
        "LLM Orchestration",
        "Multi-Agent Systems",
        "Microservices",
        "Node.js",
        "React",
        "Automation",
        "Astro",
        "Transformers.js",
        "WebGPU",
      ],
    },
    {
      "@type": "ItemList",
      name: "Featured Projects",
      url: "https://cesarmoreno.dev/#projects",
      numberOfItems: 4,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Agentes Hub",
          url: "https://github.com/cmorenogit/agentes-hub",
          description:
            "Multi-agent system for automated PR code reviews with 97.5% token savings",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Prompt Hub",
          url: "https://github.com/cmorenogit/prompt-hub",
          description:
            "Centralized prompt management with versioning and performance tracking",
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Prism",
          url: "https://github.com/cmorenogit/prism",
          description:
            "CLI tool orchestrating structured debates between Claude, GPT, and Gemini",
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Claude Statusline",
          url: "https://github.com/cmorenogit/claude-statusline",
          description:
            "Rich two-line statusline for Claude Code CLI with context usage and rate limits",
        },
      ],
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Full Stack Engineer, AI Engineer, AI Agents, LLM Orchestration, TypeScript, Node.js, React, NestJS, Microservices, Automation, Multi-Agent Systems" />
    <meta name="author" content="Cesar Moreno" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content="https://cesarmoreno.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Building AI agents that automate complex workflows" />
    <meta property="og:site_name" content="Cesar Moreno" />
    <meta property="og:image" content="https://cesarmoreno.dev/og-image.png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Building AI agents that automate complex workflows" />
    <meta name="twitter:image" content="https://cesarmoreno.dev/og-image.png" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="antialiased">
    <slot />

    <!-- Back to top (mobile) -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-20 left-4 z-40 flex h-10 w-10 items-center justify-center rounded-full border border-accent/15 bg-navy-light/90 text-accent backdrop-blur-sm transition-all duration-300 hover:border-accent/30 hover:bg-accent/10 lg:hidden"
      style="opacity: 0; pointer-events: none; transform: translateY(8px);"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
    </button>

    <ChatWidget client:load />
    <Analytics />

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                const items = entry.target.querySelectorAll('.fade-in-item');
                items.forEach((item, i) => {
                  setTimeout(() => item.classList.add('visible'), i * 100);
                });
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

        // Back to top button
        const btn = document.getElementById('back-to-top');
        if (btn) {
          window.addEventListener('scroll', () => {
            if (window.scrollY > 600) {
              btn.style.opacity = '1';
              btn.style.pointerEvents = 'auto';
              btn.style.transform = 'translateY(0)';
            } else {
              btn.style.opacity = '0';
              btn.style.pointerEvents = 'none';
              btn.style.transform = 'translateY(8px)';
            }
          }, { passive: true });
          btn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      });
    </script>
  </body>
</html>
